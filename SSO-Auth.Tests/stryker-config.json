{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-net/master/src/Stryker.Core/Stryker.Core/Options/stryker-schema.json",
  "stryker-config": {
    "project": "SSO-Auth.csproj",
    "target-framework": "net9.0",
    "coverage-analysis": "perTest",
    "reporters": ["html", "markdown", "progress", "cleartext"],
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 0
    },
    "mutate": [
      "Api/Saml/*.cs",
      "Api/Oidc/*.cs",
      "Api/Authz/RolePrivilegeMapper.cs",
      "Api/Session/LoginStatusMapper.cs",
      "Api/Linking/AdoptionEligibilityResolver.cs"
    ]
  }
}
