# The Jellyfin server state and the unpacked plugin are generated at run time (the workflow, or the
# local build step in test/e2e/README.md) — never committed.
jellyfin/config/

# Authelia harness TLS cert is generated at run time (workflow step / local openssl), never committed.
authelia/tls.crt
authelia/tls.key

# Kanidm harness TLS cert is generated at run time (workflow step / local openssl), never committed.
kanidm/chain.pem
kanidm/key.pem
